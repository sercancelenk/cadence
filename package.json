{
  "name": "cadence",
  "version": "0.2.0",
  "private": true,
  "description": "Cadence — a local-first workspace for people, tasks, notes, goals and reminders.",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sercancelenk/cadence.git"
  },
  "scripts": {
    "build:reminder-helper": "node scripts/build-macos-reminder-helper.mjs",
    "build:reminder-helper-win": "node scripts/build-windows-reminder-helper.mjs",
    "predev": "node scripts/build-macos-reminder-helper.mjs || true",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:web": "vite build",
    "build:pwa": "cross-env CADENCE_PWA=1 vite build",
    "build:pages": "npm run build:pwa && node scripts/build-pages.mjs",
    "build": "npm run build:reminder-helper && vite build && electron-builder",
    "build:enterprise": "npm run build:reminder-helper && cross-env CADENCE_DISTRIBUTION=enterprise vite build && cross-env CADENCE_DISTRIBUTION=enterprise electron-builder --config electron-builder.enterprise.json",
    "preview": "vite preview",
    "preview:landing": "npx --yes serve dist -l 4173",
    "build:release": "npm run build:reminder-helper && vite build && electron-builder --publish always",
    "build:release:enterprise": "cross-env CADENCE_DISTRIBUTION=enterprise vite build && cross-env CADENCE_DISTRIBUTION=enterprise electron-builder --config electron-builder.enterprise.json --publish always",
    "release:validate": "node scripts/validate-release-config.mjs",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "check:env": "node scripts/check-env.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "check:release": "npm run typecheck && npm test && npm run build:web && npx playwright install chromium && npm run test:e2e",
    "ci:local": "cross-env ELECTRON_SKIP_BINARY_DOWNLOAD=1 VITE_GOOGLE_OAUTH_CLIENT_ID=ci-placeholder.apps.googleusercontent.com npm run typecheck && npm test && npm run test:coverage && npm run build:web && npx playwright install chromium && npm run test:e2e && npm run build:pwa",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "demo:generate": "node scripts/generate-screenshot-demo.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-highlight": "^2.11.5",
    "@tiptap/extension-image": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/extension-task-item": "^2.11.5",
    "@tiptap/extension-task-list": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/html": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.6",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "qs": "6.15.2",
    "shell-quote": ">=1.8.4",
    "esbuild": ">=0.28.1"
  },
  "build": {
    "appId": "com.cadence.app",
    "productName": "Cadence",
    "extraMetadata": {
      "cadenceAppId": "com.cadence.app"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "cadence",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "protocols": [
        {
          "name": "Cadence",
          "schemes": [
            "cadence"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "electron/reminder/native/cadence-notify-schedule",
          "to": "MacOS/helpers/cadence-notify-schedule"
        }
      ],
      "binaries": [
        "Contents/MacOS/helpers/cadence-notify-schedule"
      ],
      "x64ArchFiles": "**/cadence-notify-schedule",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "writeUpdateInfo": true,
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraFiles": [
        {
          "from": "electron/reminder/native-windows/out/cadence-notify-schedule.exe",
          "to": "."
        }
      ]
    }
  }
}
