{
  "name": "cadence",
  "version": "0.2.0",
  "private": true,
  "description": "Cadence — a local-first workspace for people, tasks, notes, goals and reminders.",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sercancelenk/cadence.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:web": "vite build",
    "build:pwa": "cross-env CADENCE_PWA=1 vite build",
    "build:pages": "npm run build:pwa && node scripts/build-pages.mjs",
    "build": "vite build && electron-builder",
    "build:enterprise": "cross-env CADENCE_DISTRIBUTION=enterprise vite build && cross-env CADENCE_DISTRIBUTION=enterprise electron-builder --config electron-builder.enterprise.json",
    "preview": "vite preview",
    "preview:landing": "npx --yes serve dist -l 4173",
    "build:release": "vite build && electron-builder --publish always",
    "build:release:enterprise": "cross-env CADENCE_DISTRIBUTION=enterprise vite build && cross-env CADENCE_DISTRIBUTION=enterprise electron-builder --config electron-builder.enterprise.json --publish always",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "check:env": "node scripts/check-env.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.cadence.app",
    "productName": "Cadence",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "cadence",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "writeUpdateInfo": true,
      "sign": false
    }
  }
}
